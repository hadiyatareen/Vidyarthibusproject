<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vidyarthi-Bus"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp" />

    <!-- SCREEN 1 -->
    <LinearLayout
        android:id="@+id/selectBusLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Bus Route"
            android:textSize="18sp"
            android:layout_marginBottom="10dp" />

        <Spinner
            android:id="@+id/busSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/checkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Crowd Status" />
    </LinearLayout>

    <!-- SCREEN 2 -->
    <LinearLayout
        android:id="@+id/crowdLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/busInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bus No:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/driverText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver:"
            android:textSize="16sp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:text="Waiting for status..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:background="#E0E0E0"/>

        <ProgressBar
            android:id="@+id/crowdProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="10dp"/>

        <!-- NEW: Back Button -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="← Back to Route Selection"
            android:layout_marginTop="20dp"/>

        <!-- SHARED AUTO CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/sharedAutoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFF3E0">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛺 Bus Full? Try Shared Auto:"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#E65100"/>

                <TextView
                    android:id="@+id/autoContact1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Ravi Auto: 98765 43210"
                    android:layout_marginTop="12dp"
                    android:textSize="16sp"
                    android:textColor="#1976D2"/>

                <TextView
                    android:id="@+id/autoContact2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Suresh Auto: 87654 32109"
                    android:layout_marginTop="8dp"
                    android:textSize="16sp"
                    android:textColor="#1976D2"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</LinearLayout>